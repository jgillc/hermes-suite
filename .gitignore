# =============================================================================
# .gitignore — Hermes Suite
# =============================================================================

# Environment / secrets (API keys, tokens)
.env
.env.*
!.env.example

# Python virtual environments
.venv
venv/
env/

# Hermes data (mounted from host, never in repo)
data/
hermes/

# Build artifacts
*.tar
*.tar.gz
*.log

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python cache (shouldn't be here but just in case)
__pycache__/
*.pyc

# Local install — cloned repos
/hermes_upstream/
/hermes_webui/
*.pid
nohup.out

# Local install scripts (not tracked — run to set up)
/hermes_local/

# Container symlink
/hermes_container/versions.env
